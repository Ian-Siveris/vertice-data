generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Perfil {
  id                Int      @id @default(autoincrement())
  razaoSocial       String
  cnpj              String
  porte             String   @default("Nao informado")
  sede              String   @default("Nao informada")
  cnaes             String
  atestadosResumo   String
  diferenciais      String   @default("Nenhum")
  capitalSocial     Float
  patrimonioLiquido Float
}

model Licitacao {
  id              Int      @id @default(autoincrement())
  orgao           String
  objeto          String
  valorEstimado   String
  dataAbertura    String
  scoreIA         Int
  justificativa   String
  createdAt       DateTime @default(now())
}